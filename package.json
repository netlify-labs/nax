{
  "name": "netlify-agent-executor",
  "version": "1.0.1",
  "description": "Run multi step Netlify agent workflows using the world's leading AI models.",
  "type": "commonjs",
  "bin": {
    "nax": "src/cli/nax.js"
  },
  "files": [
    "src",
    "workflows",
    "src/dashboard/web/dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/cli/nax.js",
    "check": "node --check src/cli/nax.js && find src -path src/dashboard/web/dist -prune -o -name '*.js' -print0 | xargs -0 -n 1 node --check && npm run check:import-direction && npm run check:jsdoc-types && npm run typecheck",
    "check:cli-help": "node scripts/check-cli-help.js",
    "check:import-direction": "node scripts/check-import-direction.js",
    "check:jsdoc-types": "node scripts/check-jsdoc-types.js",
    "typecheck": "tsc -p tsconfig.json",
    "dry-run": "node src/cli/nax.js issue review --dry --force",
    "try:multiline": "node scripts/try-multiline.js",
    "docs:workflows": "md-magic --file workflows/README.md --config ./.github/markdown.config.js",
    "dashboard:dev": "vite --config src/dashboard/web/vite.config.mjs",
    "dashboard:dev:real": "NAX_DASHBOARD_API_URL=${NAX_DASHBOARD_API_URL:-http://127.0.0.1:53734} vite --config src/dashboard/web/vite.config.mjs",
    "dashboard:build": "vite build --config src/dashboard/web/vite.config.mjs",
    "dashboard:preview": "vite preview --config src/dashboard/web/vite.config.mjs",
    "dashboard:smoke": "playwright test tests/e2e/dashboard.spec.js",
    "prepare": "npm run dashboard:build",
    "prepack": "npm run dashboard:build",
    "test": "node --import tsx --test tests/unit/*.test.js tests/unit/*.test.ts tests/integration/*.test.js",
    "publish": "git push origin && git push origin --tags",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "keywords": [
    "netlify",
    "agents",
    "agent-runner",
    "claude",
    "gemini",
    "codex",
    "ai",
    "workflow",
    "cli",
    "nax"
  ],
  "author": "David Wells <hello@davidwells.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netlify-labs/nax.git"
  },
  "bugs": {
    "url": "https://github.com/netlify-labs/nax/issues"
  },
  "homepage": "https://github.com/netlify-labs/nax#readme",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@davidwells/box-logger": "^2.0.8",
    "@davidwells/graceful-exit": "^0.0.2",
    "@davidwells/md-utils": "^0.0.54",
    "@netlify/blobs": "^10.7.9",
    "@netlify/build-info": "^10.5.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "commander": "^14.0.3",
    "comment-block-parser": "^1.5.4",
    "configorama": "^0.9.15",
    "hono": "^4.12.26",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/notifications": "^9.3.2",
    "@playwright/test": "^1.61.0",
    "@streamdown/code": "^1.1.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.11.0",
    "code-inspector-plugin": "^1.6.1",
    "lucide-react": "^1.21.0",
    "markdown-magic": "^4.10.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
