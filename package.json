{
  "name": "netlify-agent-executor",
  "version": "0.1.0",
  "description": "Run multi step Netlify agent workflows using the worlds leading AI models.",
  "private": true,
  "type": "commonjs",
  "bin": {
    "nax": "./bin/nax.js"
  },
  "scripts": {
    "start": "node bin/nax.js",
    "check": "node --check bin/nax.js && for f in lib/*.js; do node --check \"$f\"; done",
    "dry-run": "node bin/nax.js issue review --dry --force",
    "test": "node --test"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@davidwells/box-logger": "^2.0.8",
    "@davidwells/graceful-exit": "^0.0.2",
    "commander": "^14.0.3",
    "comment-block-parser": "^1.5.4",
    "configorama": "^0.9.15"
  }
}
